# --- CỰC KỲ QUAN TRỌNG: Môi trường & Bảo mật ---
.env
.env.*
!.env.example
*.local

# --- BACKEND (Python/FastAPI) ---
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
# Database local (nếu bạn dùng sqlite để test)
*.db
*.sqlite3

# --- FRONTEND (Node/Vue/Vite) ---
node_modules/
dist/
dist-ssr/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# --- DỮ LIỆU TẠM (Uploads) ---
# Nếu bạn không muốn push các ảnh Shipper chụp lên Git
backend/uploads/pod/*
!backend/uploads/pod/.gitkeep