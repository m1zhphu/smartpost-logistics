# ============================================================
# SpeedlightApp_fn — Environment Variables Template
# Sao chép file này thành .env và điền giá trị thực tế vào.
# KHÔNG commit file .env lên Git!
# ============================================================

# URL Backend API (FastAPI server)
EXPO_PUBLIC_API_BASE_URL=http://<server-ip>:<port>

# URL dịch vụ cập nhật vị trí GPS (Location Tracking)
EXPO_PUBLIC_LOCATION_URL=https://
# EXPO_PUBLIC_LOCATION_URL=https://maps.xien.io.vn/update_location.php



# URL dịch vụ OCR quét vận đơn (AI Extract)
EXPO_PUBLIC_OCR_URL=https://
# EXPO_PUBLIC_OCR_URL=https://speedlight.minhhien.click/extract